package org.babymonitor.groep.model;

public class Groep {

    private String GroepID;
    private String naam;

    public Groep(String GroepID, String naam) {
        this.GroepID = GroepID;
        this.naam = naam;
    }

    public String getGroepID() {
        return GroepID;
    }

    public String getNaam() {
        return naam;
    }
}