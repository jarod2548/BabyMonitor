@Service
public class GroepService {

    private final ConnectionService connectionService;

    public GroepService(ConnectionService connectionService) {
        this.connectionService = connectionService;
    }

    public List<Groep> getAlleGroepen() {
        List<Groep> groepen = new ArrayList<>();

        for (String groepID : connectionService.getGroepIds()) {
            groepen.add(new Groep(
                groepID,
                "Groep " + groepID.substring(0, 5),
                "Instructeur A"
            ));
        }

        return groepen;
    }
}